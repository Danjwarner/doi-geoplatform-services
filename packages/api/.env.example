# Server Configuration
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geoservices
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# DOI Identity Configuration
DOI_IDENTITY_ISSUER=https://identity.doi.gov
DOI_IDENTITY_AUDIENCE=geoservices
DOI_IDENTITY_ALGORITHM=RS256
# DOI_IDENTITY_PUBLIC_KEY=<base64-encoded-public-key>
# DOI_IDENTITY_SECRET=<secret-for-hs256>

# Redis/ElastiCache Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Logging
LOG_LEVEL=info
SERVICE_NAME=geoservices-api

# Application Version
APP_VERSION=0.1.0
